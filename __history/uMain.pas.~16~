unit uMain;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes,
  System.Variants, FMX.Types, FMX.Controls, FMX.Forms,
  FMX.Graphics, FMX.Dialogs, FMX.Edit,
  FMX.Controls.Presentation, FMX.StdCtrls,
  FMX.Layouts, uData, System.ImageList,
  FMX.ImgList, System.UIConsts, FMX.ListBox;

type
  TForm1 = class(TForm)
    lytCartas: TLayout;
    btnIniciar: TButton;
    edtJ1: TEdit;
    edtJ2: TEdit;
    edtTematica: TEdit;
    lblTurno: TLabel;
    lblPointsJ1: TLabel;
    Label2: TLabel;
    pnlTop: TPanel;
    pnlBajo: TPanel;
    ImageList1: TImageList;
    cmbNoCar: TComboBox;

    procedure btnIniciarClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);

  private
    procedure ActualizarMarcador(
      PtsJ1,
      PtsJ2,
      TurnoActual: Integer
    );

  public
  end;

var
  Form1: TForm1;

implementation

{$R *.fmx}

procedure TForm1.FormCreate(Sender: TObject);
begin
  // Conectamos el cerebro con la interfazprocedure TForm1.FormCreate(Sender: TObject);
begin
  Cerebro.OnActualizarUI := ActualizarMarcador;
end;
end;

procedure TForm1.btnIniciarClick(Sender: TObject);
var
  TotalCartas: Integer;
begin
  // N·mero de cartas
  TotalCartas := StrToIntDef(edtNoCar.Text, 12);

  // Validaci¾n
  if (TotalCartas <= 0) or (TotalCartas mod 2 <> 0) then
  begin
    ShowMessage(
      'Por favor escribe un n·mero PAR de cartas ' +
      '(6, 8, 10, 12, etc).'
    );
    Exit;
  end;

  // Validar nombres
  if Trim(edtJ1.Text) = '' then
  begin
    ShowMessage('Escribe el nombre del Jugador 1');
    Exit;
  end;

  if Trim(edtJ2.Text) = '' then
  begin
    ShowMessage('Escribe el nombre del Jugador 2');
    Exit;
  end;

  // Iniciar juego
  Cerebro.IniciarJuego(
    TotalCartas div 2,
    lytCartas,
    ImageList1,
    edtJ1.Text,
    edtJ2.Text
  );
end;

procedure TForm1.ActualizarMarcador(
  PtsJ1,
  PtsJ2,
  TurnoActual: Integer
);
begin
  // Puntos jugador 1
  lblPointsJ1.Text :=
    edtJ1.Text + ': ' + IntToStr(PtsJ1);

  // Puntos jugador 2
  Label2.Text :=
    edtJ2.Text + ': ' + IntToStr(PtsJ2);

  // Turno actual
  if TurnoActual = 1 then
  begin
    lblTurno.Text :=
      ' Turno de: ' + edtJ1.Text;

    lblTurno.TextSettings.FontColor :=
      TAlphaColorRec.Blue;
  end
  else
  begin
    lblTurno.Text :=
      ' Turno de: ' + edtJ2.Text;

    lblTurno.TextSettings.FontColor :=
      TAlphaColorRec.Red;
  end;
end;

end.
