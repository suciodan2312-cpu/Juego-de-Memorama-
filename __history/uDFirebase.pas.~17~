unit uDFirebase;

interface

uses
  System.SysUtils, System.Classes, REST.Types, REST.Client,
  Data.Bind.Components, Data.Bind.ObjectScope, System.JSON;

type
  // Mulo de datos centralizado para el empaquetado e intercambio de paquetes JSON de red
  TdmFirebase = class(TDataModule)
    RESTClient1: TRESTClient;     // Contiene la URL base de tu Realtime Database de Firebase
    RESTRequest1: TRESTRequest;   // Configura los par疥etros, recursos (.json) y verbos HTTP (GET, PUT, PATCH)
    RESTResponse1: TRESTResponse; // Captura las cadenas de texto JSON devueltas por el servidor
  private
  public
    procedure ProbarConexion;
    procedure SubirInicioJuego(const ConfigJSON: string);
    function DescargarPartida: string;
    procedure ActualizarEstadoNube(TurnoActual, Puntos1, Puntos2, Carta1, Carta2: Integer; const Encontradas: string);
    procedure SubirNombreJ2(Nombre: string);
  end;

var
  dmFirebase: TdmFirebase;

implementation

{%CLASSGROUP 'FMX.Controls.TControl'}
{$R *.dfm}

function TdmFirebase.DescargarPartida: string;
begin
  // OBJETIVO: Realizar la descarga del estado actual de la partida desde Firebase Realtime Database
  // utilizando el verbo HTTP GET sobre el recurso 'PartidaActual.json' para la sincronizaci as匤crona.

  RESTRequest1.Resource := 'PartidaActual.json';
  RESTRequest1.Method := rmGET; // Verbo GET: Utilizado exclusivamente para lectura/descarga de datos

  RESTRequest1.ClearBody;
  RESTRequest1.Execute;

  Result := RESTResponse1.Content; // Retorna el cuerpo JSON puro descargado
end;

procedure TdmFirebase.ProbarConexion;
begin
  // OBJETIVO: Verificar la comunicaci activa y la correcta configuraci de red con el nodo
  // remoto escribiendo un paquete JSON plano de prueba mediante el m騁odo HTTP PUT.

  RESTRequest1.Resource := 'Prueba.json';
  RESTRequest1.Method := rmPUT; // Verbo PUT: Sobrescribe por completo el nodo especificado

  RESTRequest1.ClearBody;
  RESTRequest1.AddBody('{"Mensaje": "Hola desde Delphi FMX", "Estado": "Conectado"}',
                        ctAPPLICATION_JSON);

  RESTRequest1.Execute;
end;

procedure TdmFirebase.SubirInicioJuego(const ConfigJSON: string);
begin
  // OBJETIVO: Inicializar los par疥etros centrales de la sesi en la nube
  RESTRequest1.Resource := 'PartidaActual.json';
  RESTRequest1.Method := rmPUT;
  RESTRequest1.ClearBody;
  RESTRequest1.AddBody(ConfigJSON, ctAPPLICATION_JSON);
  RESTRequest1.Execute;
end;

procedure TdmFirebase.ActualizarEstadoNube(TurnoActual, Puntos1, Puntos2, Carta1, Carta2: Integer; const Encontradas: string);
var
  EstadoObj: TJSONObject;
begin
  // OBJETIVO: Sincronizar de forma parcial (PATCH) las variables de control del juego
  // para que el contrincante pueda replicar instant疣eamente las cartas volteadas.

  RESTRequest1.Resource := 'PartidaActual.json';
  RESTRequest1.Method := rmPATCH;
  RESTRequest1.ClearBody;

  EstadoObj := TJSONObject.Create;
  try
    EstadoObj.AddPair('turno', TJSONNumber.Create(TurnoActual));
    EstadoObj.AddPair('puntosJ1', TJSONNumber.Create(Puntos1));
    EstadoObj.AddPair('puntosJ2', TJSONNumber.Create(Puntos2));
    EstadoObj.AddPair('carta1', TJSONNumber.Create(Carta1));
    EstadoObj.AddPair('carta2', TJSONNumber.Create(Carta2));
    EstadoObj.AddPair('encontradas', Encontradas);

    RESTRequest1.AddBody(EstadoObj.ToString, ctAPPLICATION_JSON);
    RESTRequest1.Execute;
  finally
    EstadoObj.Free;
  end;
end;

procedure TdmFirebase.SubirNombreJ2(Nombre: string);
var
  NombreObj: TJSONObject;
begin
  // OBJETIVO: Adjuntar de forma remota el string del nombre del competidor 2.

  RESTRequest1.Resource := 'PartidaActual.json';
  RESTRequest1.Method := rmPATCH;
  RESTRequest1.ClearBody;

  NombreObj := TJSONObject.Create;
  try
    NombreObj.AddPair('j2', Nombre);
    RESTRequest1.AddBody(NombreObj.ToString, ctAPPLICATION_JSON);
    RESTRequest1.Execute;
  finally
    NombreObj.Free;
  end;
end;

end.
