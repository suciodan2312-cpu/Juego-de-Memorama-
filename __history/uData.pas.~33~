unit uData;

interface

uses
  System.SysUtils, System.Classes, System.Math, FMX.Types, FMX.Layouts,
  FMX.Objects, FMX.Dialogs, System.UIConsts, System.UITypes,
  System.Types, FMX.ImgList, FMX.Graphics, FMX.ListBox,
  System.IOUtils;

type
  // Estructura lógica individual para modelar el comportamiento de cada carta
  TCartaLogica = record
    IDPareja: Integer;     // ID numérico para emparejamiento (Cartas con el mismo ID hacen par) [cite: 196, 197]
    Volteada: Boolean;     // True = Cara hacia arriba, False = Cara hacia abajo [cite: 198]
    Encontrada: Boolean;   // True = Ya fue adivinada por un jugador (Salió del flujo activo) [cite: 199]
    BotonVisual: TImage;   // Puntero directo al componente visual TImage incrustado en el Layout [cite: 200]
  end;

  // Firma de método para el delegado que notificará cambios de estado a la interfaz
  TActualizarUIEvent = procedure(PtsJ1, PtsJ2, TurnoActual: Integer) of object;

  // Clase controladora central: Maneja toda la lógica algorítmica del juego
  TCerebroMemorama = class
  private
    FTablero: TLayout;               // Referencia al contenedor de diseño gráfico [cite: 206]
    FListaImagenes: TCustomImageList;// Almacén de texturas asignado [cite: 207]
    FPrimerCarta, FSegundaCarta: Integer; // Índices de las cartas seleccionadas en el turno actual (-1 = ninguna) [cite: 208, 210]
    FTimerEspera: TTimer;            // Cronómetro de penalización (mantiene las cartas arriba al fallar) [cite: 211]

    procedure GenerarYRevolverCartas(TotalCartas: Integer);
    procedure CartaClickeada(Sender: TObject);
    procedure TimerEsperaTick(Sender: TObject);
    procedure MostrarImagen(CartaIdx, ImgIndex: Integer);
    procedure CalcularGrid(Total: Integer; out Cols, Filas: Integer);

  public
    Cartas: array of TCartaLogica;   // Arreglo dinámico que contiene el tablero de juego completo [cite: 213]
    ParesTotales: Integer;           // Cantidad de pares requeridos para dar fin al juego [cite: 214]
    Turno: Integer;                  // Control de turno activo (1 o 2) [cite: 215]
    PtsJ1, PtsJ2: Integer;           // Contadores de puntuación independientes [cite: 216]
    NombreJ1, NombreJ2: String;      // Nombres vigentes de los competidores [cite: 217]
    OnActualizarUI: TActualizarUIEvent; // Evento invocado al modificar puntajes o turnos [cite: 219]
    MiRol: Integer;                  // Identidad de red local (1 = Host, 2 = Invitado) [cite: 218]

    constructor Create;
    destructor Destroy; override;

    procedure ConfigurarOpcionesCartas(AComboBox: TComboBox);
    procedure ListarTemas(AComboBox: TComboBox);
    procedure CargarImagenesDeCarpeta(NombreTema: String; AImageList: TImageList);

    procedure IniciarJuego(
      TextoCantCartas: String;
      ContenedorVisual: TLayout;
      ListaImagenes: TCustomImageList;
      J1, J2: String
    );
  end;

var
  Cerebro: TCerebroMemorama; // Instancia global de acceso público unificado

implementation

uses
  uDFirebase;

{ TCerebroMemorama }

constructor TCerebroMemorama.Create;
begin
  // OBJETIVO: Inicializar la clase instanciando el objeto interno FTimerEspera,
  // configurando su intervalo a 800ms y enlazando su evento de ejecución[cite: 222].

  // Instanciación y parametrización del reloj de retraso de pares fallidos
  FTimerEspera := TTimer.Create(nil);
  FTimerEspera.Enabled := False;
  FTimerEspera.Interval := 800; // 800 milisegundos de visualización libre
  FTimerEspera.OnTimer := TimerEsperaTick;
end;

destructor TCerebroMemorama.Destroy;
begin
  // OBJETIVO: El destructor se asegura de liberar el espacio ocupado por el temporizador
  // en la memoria al cerrar el programa[cite: 223].

  FTimerEspera.Free;
  inherited;
end;

procedure TCerebroMemorama.ConfigurarOpcionesCartas(AComboBox: TComboBox);
begin
  // OBJETIVO: Llena un componente TComboBox con las opciones preestablecidas de escala
  // para la cantidad de cartas del juego, dejando seleccionada la opción por defecto (8 cartas)[cite: 225].

  AComboBox.Items.Clear;
  AComboBox.Items.Add('4');
  AComboBox.Items.Add('8');
  AComboBox.Items.Add('12');
  AComboBox.Items.Add('16');
  AComboBox.Items.Add('20');
  AComboBox.ItemIndex := 1; // Selección por defecto: 8 cartas
end;

procedure TCerebroMemorama.ListarTemas(AComboBox: TComboBox);
var
  RutaBase, RutaTemas: string;
  Carpetas: TStringDynArray;
  Carpeta: string;
begin
  // OBJETIVO: Utiliza las directivas de compilación condicional ($IFDEF MSWINDOWS) para ubicar
  // la ruta de almacenamiento correcta del sistema operativo y busca de forma automática un directorio
  // llamado Temas. Lee todas las subcarpetas internas e inserta sus nombres en el ComboBox[cite: 227, 228].

  AComboBox.Items.Clear;

  // Adaptación de rutas de archivos multiplataforma (Windows/Android)
  {$IFDEF MSWINDOWS}
  RutaBase := TPath.GetDirectoryName(ParamStr(0));
  {$ELSE}
  RutaBase := TPath.GetDocumentsPath;
  {$ENDIF}

  RutaTemas := TPath.Combine(RutaBase, 'Temas');

  // Escanea directorios físicos para transformarlos en opciones de la interfaz
  if TDirectory.Exists(RutaTemas) then
  begin
    Carpetas := TDirectory.GetDirectories(RutaTemas);
    for Carpeta in Carpetas do
      AComboBox.Items.Add(TPath.GetFileName(Carpeta));

    if AComboBox.Items.Count > 0 then AComboBox.ItemIndex := 0;
  end;
end;

procedure TCerebroMemorama.CargarImagenesDeCarpeta(NombreTema: String; AImageList: TImageList);
var
  RutaBase, RutaTema, Archivo, NombreArchivo: string;
  Archivos: TStringDynArray;
  SourceItem: TCustomSourceItem;
  RutaReverso: string;
  ListaCaras: TStringList;
begin
  // OBJETIVO: Limpia el contenedor de imágenes y lee todos los archivos con extensión .png
  // de la carpeta temática seleccionada. Implementa un filtro estricto mediante SameText: el archivo
  // llamado textualmente reverso.png se inyecta de forma mandatoria en el Índice 0 (fondo de cartas ocultas),
  // mientras que el resto de imágenes se cargan en los índices sucesivos[cite: 230, 231].

  AImageList.Source.Clear;

  {$IFDEF MSWINDOWS}
  RutaBase := TPath.GetDirectoryName(ParamStr(0));
  {$ELSE}
  RutaBase := TPath.GetDocumentsPath;
  {$ENDIF}

  RutaTema := TPath.Combine(TPath.Combine(RutaBase, 'Temas'), NombreTema);

  if not TDirectory.Exists(RutaTema) then Exit;

  Archivos := TDirectory.GetFiles(RutaTema, '*.png');
  RutaReverso := '';
  ListaCaras := TStringList.Create;

  try
    // Clasifica el reverso oficial del mazo separándolo de las caras frontales
    for Archivo in Archivos do
    begin
      NombreArchivo := TPath.GetFileName(Archivo);
      if SameText(NombreArchivo, 'reverso.png') then
        RutaReverso := Archivo
      else
        ListaCaras.Add(Archivo);
    end;

    // El reverso se posiciona de forma fija en la posición 0 del mazo virtual
    if RutaReverso <> '' then
    begin
      SourceItem := AImageList.Source.Add;
      SourceItem.MultiResBitmap.Add.Bitmap.LoadFromFile(RutaReverso);
    end;

    // Carga recursiva de todas las texturas de juego utilizables
    for Archivo in ListaCaras do
    begin
      SourceItem := AImageList.Source.Add;
      SourceItem.MultiResBitmap.Add.Bitmap.LoadFromFile(Archivo);
    end;
  finally
    ListaCaras.Free;
  end;
end;

procedure TCerebroMemorama.CalcularGrid(Total: Integer; out Cols, Filas: Integer);
begin
  // OBJETIVO: Algoritmo matemático para calcular dinámicamente la disposición de filas y
  // columnas en el tablero en base al total de cartas seleccionadas, buscando aproximarse a una forma
  // cuadrática regular. Invierte filas por columnas si el Layout es más ancho que alto[cite: 233, 234].

  // Algoritmo matemático para distribuir de forma rectangular las cartas según el total
  Cols := Ceil(Sqrt(Total));
  while (Total mod Cols <> 0) do Inc(Cols);
  Filas := Total div Cols;

  // Ajusta proporcionalmente la cuadrícula si el Layout es predominantemente horizontal
  if (FTablero.Width > FTablero.Height) and (Filas > Cols) then
  begin
    Total := Cols; Cols := Filas; Filas := Total;
  end;
end;

procedure TCerebroMemorama.IniciarJuego(TextoCantCartas: String; ContenedorVisual: TLayout;
  ListaImagenes: TCustomImageList; J1, J2: String);
var
  TotalCartas, Cols, Filas, I, C, F: Integer;
  Margen, AnchoCarta, AltoCarta: Single;
begin
  // OBJETIVO: Prepara el inicio del juego local. Limpia cualquier componente visual remanente
  // en el layout, inicializa los contadores a cero, barajea las cartas, calcula el tamaño exacto
  // en píxeles de cada carta restando los márgenes, genera dinámicamente los TImage y asigna el OnClick[cite: 236].

  NombreJ1 := J1; NombreJ2 := J2;
  FTablero := ContenedorVisual;
  FListaImagenes := ListaImagenes;
  FTablero.DeleteChildren; // Elimina cartas de partidas previas de la pantalla

  TotalCartas := StrToIntDef(TextoCantCartas, 8);
  ParesTotales := TotalCartas div 2;
  Turno := 1; PtsJ1 := 0; PtsJ2 := 0;
  FPrimerCarta := -1; FSegundaCarta := -1;

  if Assigned(OnActualizarUI) then OnActualizarUI(PtsJ1, PtsJ2, Turno);

  GenerarYRevolverCartas(TotalCartas);
  CalcularGrid(TotalCartas, Cols, Filas);

  Margen := 10;
  // Determina el ancho y alto exacto de cada carta restando los espacios de margen
  AnchoCarta := (FTablero.Width - (Margen * (Cols + 1))) / Cols;
  AltoCarta := (FTablero.Height - (Margen * (Filas + 1))) / Filas;

  // Instanciación dinámica y posicionamiento espacial de cada carta en la interfaz
  for I := 0 to TotalCartas - 1 do
  begin
    F := I div Cols; C := I mod Cols;

    Cartas[I].BotonVisual := TImage.Create(FTablero);
    Cartas[I].BotonVisual.Parent := FTablero;

    Cartas[I].BotonVisual.Width := AnchoCarta;
    Cartas[I].BotonVisual.Height := AltoCarta;
    Cartas[I].BotonVisual.Position.X := Margen + (C * (AnchoCarta + Margen));
    Cartas[I].BotonVisual.Position.Y := Margen + (F * (AltoCarta + Margen));

    Cartas[I].BotonVisual.Tag := I; // Almacena el índice de la carta en su Tag para reconocerla al clickear
    Cartas[I].BotonVisual.WrapMode := TImageWrapMode.Stretch;

    MostrarImagen(I, 0); // Arrancan todas mostrando el reverso (Índice 0)
    Cartas[I].BotonVisual.OnClick := CartaClickeada;
  end;
end;

procedure TCerebroMemorama.MostrarImagen(CartaIdx, ImgIndex: Integer);
begin
  // OBJETIVO: Realiza la asignación física del mapa de bits (Bitmap.Assign) desde el
  // ImageList hacia el control gráfico TImage de una carta específica en base a su índice[cite: 238].

  if not Assigned(FListaImagenes) or (ImgIndex >= FListaImagenes.Source.Count) then Exit;

  Cartas[CartaIdx].BotonVisual.Bitmap.Assign(
    FListaImagenes.Source.Items[ImgIndex].MultiResBitmap.Items[0].Bitmap
  );
end;

procedure TCerebroMemorama.GenerarYRevolverCartas(TotalCartas: Integer);
var I, RndIdx: Integer; Temp: TCartaLogica;
begin
  // OBJETIVO: Aloja el espacio en memoria para el arreglo dinámico de cartas. Asigna los IDs
  // de parejas en secuencia (0, 0, 1, 1...) y posteriormente ejecuta el Algoritmo de barajado
  // de Fisher-Yates para asegurar una distribución aleatoria pura[cite: 240, 241].

  SetLength(Cartas, TotalCartas);
  for I := 0 to TotalCartas - 1 do
  begin
    Cartas[I].IDPareja := I div 2; // Asigna parejas consecutivas (0,0, 1,1, 2,2...)
    Cartas[I].Volteada := False;
    Cartas[I].Encontrada := False;
  end;

  // Algoritmo Fisher-Yates para barajar el mazo de forma uniforme y aleatoria
  Randomize;
  for I := TotalCartas - 1 downto 1 do
  begin
    RndIdx := Random(I + 1);
    Temp := Cartas[I];
    Cartas[I] := Cartas[RndIdx];
    Cartas[RndIdx] := Temp;
  end;
end;

procedure TCerebroMemorama.CartaClickeada(Sender: TObject);
var
  Idx, CantidadCaras, ImgIndex: Integer;
  StrEnc: string;
  J: Integer;
begin
  // OBJETIVO: Es la función de control principal del juego. Se activa al pulsar una carta[cite: 243].
  // REGLAS DE NEGOCIO VALIDADAS:
  // - Si el temporizador de penalización por fallo está activo, bloquea el clic[cite: 245].
  // - Bloqueo de red: Si el Turno global de la partida no coincide con MiRol, impide interactuar[cite: 246].
  // - Si la carta ya fue descubierta o está bocarriba, ignora el clic[cite: 247].
  // - Muestra la imagen calculando su índice con mod (por si hay menos imágenes que las requeridas)[cite: 248].
  // - Guarda el primer índice; al elegir la segunda, compara IDPareja[cite: 249]. Si coinciden, reduce opacidad, suma puntos y valida el fin del juego[cite: 250]. Si fallan, alterna turno y enciende FTimerEspera[cite: 251].
  // - Envío a Firebase: Serializa las posiciones resueltas en una cadena por comas y las sube a la nube[cite: 252].

  // Candado 1: Si hay penalización activa de tiempo de espera, se descartan los clics
  if FTimerEspera.Enabled then Exit;

  // Candado 2: Bloqueo de turnos multijugador para evitar jugar en el turno del oponente
  if Turno <> MiRol then Exit;

  Idx := TImage(Sender).Tag;

  // Candado 3: Ignorar si tocan una carta ya resuelta o que ya esté viendo hacia arriba
  if Cartas[Idx].Encontrada or Cartas[Idx].Volteada then Exit;

  Cartas[Idx].Volteada := True;

  // Calcula matemáticamente el índice de la imagen correspondiente basándose en su IDPareja
  CantidadCaras := FListaImagenes.Source.Count - 1;
  if CantidadCaras > 0 then
    ImgIndex := (Cartas[Idx].IDPareja mod CantidadCaras) + 1
  else
    ImgIndex := 0;

  MostrarImagen(Idx, ImgIndex);

  if FPrimerCarta = -1 then
    FPrimerCarta := Idx // Almacena la primera selección del turno
  else
  begin
    FSegundaCarta := Idx; // Almacena la segunda selección del turno

    // --- EVALUACIÓN DE PAREJA EXITOSA ---
    if Cartas[FPrimerCarta].IDPareja = Cartas[FSegundaCarta].IDPareja then
    begin
      Cartas[FPrimerCarta].Encontrada := True;
      Cartas[FSegundaCarta].Encontrada := True;
      Cartas[FPrimerCarta].BotonVisual.Opacity := 0.5;
      Cartas[FSegundaCarta].BotonVisual.Opacity := 0.5;

      if Turno = 1 then Inc(PtsJ1) else Inc(PtsJ2);

      FPrimerCarta := -1; FSegundaCarta := -1;
      if Assigned(OnActualizarUI) then OnActualizarUI(PtsJ1, PtsJ2, Turno);

      if (PtsJ1 + PtsJ2) = ParesTotales then
        ShowMessage('¡Juego Terminado! ' + NombreJ1 + ': ' + PtsJ1.ToString + ' vs ' + NombreJ2 + ': ' + PtsJ2.ToString);
    end
    else
    // --- EVENTO DE FALLO (CAMBIO DE TURNO) ---
    begin
      Turno := IfThen(Turno = 1, 2, 1); // Intercambia el turno alternadamente
      if Assigned(OnActualizarUI) then OnActualizarUI(PtsJ1, PtsJ2, Turno);
      FTimerEspera.Enabled := True; // Activa retardo visual
    end;
  end;

  // --- RECOPILACIÓN Y ENVÍO DEL ESTADO A FIREBASE ---
  StrEnc := '';
  for J := 0 to High(Cartas) do
  begin
    if Cartas[J].Encontrada then
      StrEnc := StrEnc + J.ToString + ',';
  end;

  if Assigned(dmFirebase) then
    dmFirebase.ActualizarEstadoNube(Turno, PtsJ1, PtsJ2, FPrimerCarta, FSegundaCarta, StrEnc);
end;

procedure TCerebroMemorama.TimerEsperaTick(Sender: TObject);
var
  StrEnc: string;
  J: Integer;
begin
  // OBJETIVO: Se ejecuta automáticamente 800ms después de un intento fallido. Apaga el reloj,
  // regresa las dos cartas erróneas boca abajo asignándoles el reverso (Índice 0) y resetea las
  // variables de control. Al finalizar, actualiza el estado en la nube[cite: 254, 255, 256].

  FTimerEspera.Enabled := False;

  // Cumplido el tiempo de penalización, voltea las cartas erróneas boca abajo
  Cartas[FPrimerCarta].Volteada := False;
  MostrarImagen(FPrimerCarta, 0);

  Cartas[FSegundaCarta].Volteada := False;
  MostrarImagen(FSegundaCarta, 0);

  FPrimerCarta := -1;
  FSegundaCarta := -1;

  // Actualiza los cambios en la infraestructura de Firebase
  StrEnc := '';
  for J := 0 to High(Cartas) do
  begin
    if Cartas[J].Encontrada then
      StrEnc := StrEnc + J.ToString + ',';
  end;

  if Assigned(dmFirebase) then
    dmFirebase.ActualizarEstadoNube(Turno, PtsJ1, PtsJ2, FPrimerCarta, FSegundaCarta, StrEnc);
end;

initialization
  Cerebro := TCerebroMemorama.Create; // Auto-creación automática al arrancar la app

finalization
  Cerebro.Free; // Liberación de memoria segura al apagar la app

end.
