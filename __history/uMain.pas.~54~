  unit uMain;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes,
  System.Variants, FMX.Types, FMX.Controls, FMX.Forms,
  FMX.Graphics, FMX.Dialogs, FMX.Edit, FMX.ListBox,
  FMX.Controls.Presentation,
  FMX.Layouts, uData, System.ImageList,
  FMX.ImgList, System.UIConsts, uDFirebase, System.JSON, FMX.StdCtrls,
  FMX.DialogService; // NUEVO: Añadido para dar soporte a diálogos asíncronos nativos y seguros en Android y Windows

type
  TForm1 = class(TForm)
    // --- COMPONENTES DE INTERFAZ GRÁFICA ---
    lytCartas: TLayout;          // Contenedor dinámico donde se generan y posicionan las cartas
    btnIniciar: TButton;         // Botón para que el Host configure e inicie la partida
    edtJ1: TEdit;                // Nombre del Jugador 1 (Host) o Jugador Local
    cmbNoCar: TComboBox;         // Selector con la cantidad total de cartas en el tablero
    edtJ2: TEdit;                // Muestra el nombre del Jugador 2 (rival)
    lblTurno: TLabel;            // Etiqueta que avisa en pantalla quién debe tirar
    lblPointsJ1: TLabel;         // Marcador dinámico ("Jugador 1: X vs Jugador 2: Y")
    Label2: TLabel;
    pnlTop: TPanel;
    pnlBajo: TPanel;
    ImageList1: TImageList;      // Almacén centralizado de texturas (Índice 0 = Reverso)
    cmbTematica: TComboBox;      // Selector de carpetas de imágenes (Temas disponibles)
    Label1: TLabel;
    Label3: TLabel;
    btnConectar: TButton;        // Botón para que el Invitado se una a una partida en la nube
    TimerSincronizador: TTimer;  // Temporizador de Red (bucle de sondeo constante con Firebase)

    procedure btnIniciarClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure btnConectarClick(Sender: TObject);
    procedure TimerSincronizadorTimer(Sender: TObject);
  private
    // Actualiza los textos del marcador y turnos en la UI
    procedure ActualizarMarcador(PtsJ1, PtsJ2, TurnoActual: Integer);
  public
  end;

var
  Form1: TForm1;

implementation

{$R *.fmx}
{$R *.LgXhdpiPh.fmx ANDROID}
{$R *.NmXhdpiPh.fmx ANDROID}

procedure TForm1.FormCreate(Sender: TObject);
begin
  // OBJETIVO: Inicializar la aplicación. Vincula el evento de actualización de la UI,
  // delega al Cerebro la carga de las opciones de tamaño en cmbNoCar y escanea el
  // almacenamiento local para listar los temas disponibles en cmbTematica.

  // Vincula el evento de actualización lógica del Cerebro con el procedimiento visual local
  Cerebro.OnActualizarUI := ActualizarMarcador;

  // Carga inicial de datos estructurados en los desplegables de configuración
  Cerebro.ConfigurarOpcionesCartas(cmbNoCar);
  Cerebro.ListarTemas(cmbTematica);
end;

procedure TForm1.TimerSincronizadorTimer(Sender: TObject);
var
  JSONStr: string;
  ConfigObj: TJSONObject;
  NubeTurno, NubePtsJ1, NubePtsJ2, NubeCarta1, NubeCarta2: Integer;
  CantidadCaras, ImgIndex, CardIdx, I: Integer;
  StrEnc: string;
  ArrEnc: TArray<string>;
begin
  // OBJETIVO: Es el corazón de la sincronización en red. Desactiva temporalmente el reloj
  // para evitar colisiones de hilos, descarga el JSON de la partida, extrae las variables
  // del juego en red y actualiza la UI local.
  // LÓGICA DE SINCRONIZACIÓN:
  // - Si detecta un cambio de turno y coincide con el rol del jugador local, lanza un ShowMessage('¡Es tu turno!').
  // - Lee una cadena separada por comas (encontradas) de las cartas ya resueltas por el rival para voltearlas permanentemente y bajarles la opacidad a 0.5.
  // - Monitorea cuáles cartas están activas (NubeCarta1 y NubeCarta2) para simular visualmente el volteo que el contrincante está haciendo en su propia pantalla.

  // NUEVO: Candado de seguridad. Si el juego se está ejecutando localmente, apagamos por completo el timer de red y salimos.
  if Cerebro.EsModoLocal then
  begin
    TimerSincronizador.Enabled := False;
    Exit;
  end;

  // Apaga temporalmente el temporizador para evitar colisiones si la petición HTTP tarda
  TimerSincronizador.Enabled := False;
  try
    // Descarga el estado actual del juego desde Firebase Realtime Database
    JSONStr := dmFirebase.DescargarPartida;
    if (JSONStr = '') or (JSONStr = 'null') then Exit;

    ConfigObj := TJSONObject.ParseJSONValue(JSONStr) as TJSONObject;
    if not Assigned(ConfigObj) then Exit;

    try
      // --- 1. SINCRONIZAR NOMBRES EN TIEMPO REAL ---
      if ConfigObj.GetValue('j1') <> nil then Cerebro.NombreJ1 := ConfigObj.GetValue('j1').Value;
      if ConfigObj.GetValue('j2') <> nil then Cerebro.NombreJ2 := ConfigObj.GetValue('j2').Value;

      // --- 2. EXTRAER VARIABLES DE JUEGO ---
      if ConfigObj.GetValue('turno') <> nil then NubeTurno := ConfigObj.GetValue('turno').Value.ToInteger else NubeTurno := Cerebro.Turno;
      if ConfigObj.GetValue('puntosJ1') <> nil then NubePtsJ1 := ConfigObj.GetValue('puntosJ1').Value.ToInteger else NubePtsJ1 := 0;
      if ConfigObj.GetValue('puntosJ2') <> nil then NubePtsJ2 := ConfigObj.GetValue('puntosJ2').Value.ToInteger else NubePtsJ2 := 0;
      if ConfigObj.GetValue('carta1') <> nil then NubeCarta1 := ConfigObj.GetValue('carta1').Value.ToInteger else NubeCarta1 := -1;
      if ConfigObj.GetValue('carta2') <> nil then NubeCarta2 := ConfigObj.GetValue('carta2').Value.ToInteger else NubeCarta2 := -1;

      // --- 3. ¡AVISO DE CAMBIO DE TURNO (SHOWMESSAGE)! ---
      if (Cerebro.Turno <> NubeTurno) then
      begin
        if NubeTurno = Cerebro.MiRol then
          ShowMessage('¡Es tu turno!');
      end;

      // Actualiza las propiedades internas del Cerebro con los valores reales de la nube
      Cerebro.Turno := NubeTurno;
      Cerebro.PtsJ1 := NubePtsJ1;
      Cerebro.PtsJ2 := NubePtsJ2;

      // Redibuja los textos de la interfaz con los nuevos puntajes
      if Assigned(Cerebro.OnActualizarUI) then
        Cerebro.OnActualizarUI(Cerebro.PtsJ1, Cerebro.PtsJ2, Cerebro.Turno);

      // --- 4. LEER PARES ENCONTRADOS Y DEJARLOS VOLTEADOS ---
      if ConfigObj.GetValue('encontradas') <> nil then
      begin
        StrEnc := ConfigObj.GetValue('encontradas').Value;
        ArrEnc := StrEnc.Split([',']);
        for I := 0 to Length(ArrEnc) - 1 do
        begin
          if TryStrToInt(ArrEnc[I], CardIdx) then
          begin
            // Configura e inhabilita las cartas adivinadas por el rival o por ti
            Cerebro.Cartas[CardIdx].Encontrada := True;
            Cerebro.Cartas[CardIdx].Volteada := True;
            Cerebro.Cartas[CardIdx].BotonVisual.Opacity := 0.5; // Efecto visual semi-transparente

            CantidadCaras := ImageList1.Source.Count - 1;
            if CantidadCaras > 0 then ImgIndex := (Cerebro.Cartas[CardIdx].IDPareja mod CantidadCaras) + 1 else ImgIndex := 0;
            Cerebro.Cartas[CardIdx].BotonVisual.Bitmap.Assign(ImageList1.Source.Items[ImgIndex].MultiResBitmap.Items[0].Bitmap);
          end;
        end;
      end;

      // --- 5. REVISAR CARTAS ACTIVAS (REPLICAR MOVIMIENTOS EN VIVO) ---
      CantidadCaras := ImageList1.Source.Count - 1;
      for I := 0 to High(Cerebro.Cartas) do
      begin
        // Si el rival está volteando esta carta en su dispositivo, la volteamos en el nuestro
        if (I = NubeCarta1) or (I = NubeCarta2) then
        begin
          if not Cerebro.Cartas[I].Volteada then
          begin
            Cerebro.Cartas[I].Volteada := True;
            if CantidadCaras > 0 then ImgIndex := (Cerebro.Cartas[I].IDPareja mod CantidadCaras) + 1 else ImgIndex := 0;
            Cerebro.Cartas[I].BotonVisual.Bitmap.Assign(ImageList1.Source.Items[ImgIndex].MultiResBitmap.Items[0].Bitmap);
          end;
        end
        else
        begin
          // Si no está seleccionada en la nube ni ha sido encontrada, se oculta (boca abajo)
          if Cerebro.Cartas[I].Volteada and not Cerebro.Cartas[I].Encontrada then
          begin
            Cerebro.Cartas[I].Volteada := False;
            Cerebro.Cartas[I].BotonVisual.Bitmap.Assign(ImageList1.Source.Items[0].MultiResBitmap.Items[0].Bitmap);
          end;
        end;
      end;

    finally
      ConfigObj.Free; // Libera el objeto JSON de la memoria
    end;
  finally
    TimerSincronizador.Enabled := True; // Reactiva el reloj de red
  end;
end;

procedure TForm1.btnIniciarClick(Sender: TObject);
begin
  // MODIFICADO: Ahora el botón pregunta mediante un diálogo nativo no bloqueante si se desea jugar local o en red.
  // Esto permite dar soporte tanto a Windows como a Android de forma fluida.
  MessageDlg( // <-- SOLUCIÓN: Quitamos "TDialogService." para usar la función global directa
    '¿Desea jugar una partida LOCAL en este mismo dispositivo?' + #13#10 +
    'Seleccione "No" para iniciar una partida en RED (como Servidor/Host).',
    TMsgDlgType.mtConfirmation,
    [TMsgDlgBtn.mbYes, TMsgDlgBtn.mbNo],
    0,          // <-- Contexto de ayuda (HelpCtx) va directamente aquí
    procedure(const AResult: TModalResult)
    var
      ConfigObj: TJSONObject;
      OrdenArr: TJSONArray;
      I: Integer;
    begin
      if AResult = mrYes then
      begin
        // === CASO NUEVO: CONFIGURACIÓN MODO LOCAL ===
        Cerebro.EsModoLocal := True;         // Informamos al cerebro que es una partida local
        TimerSincronizador.Enabled := False; // Desactivamos el sondeo a internet ya que no hay servidor externo

        // Inicializa el tablero local directamente usando los nombres de los cuadros de texto
        Cerebro.CargarImagenesDeCarpeta(cmbTematica.Selected.Text, ImageList1);
        Cerebro.IniciarJuego(cmbNoCar.Selected.Text, lytCartas, ImageList1, edtJ1.Text, edtJ2.Text);
      end
      else
      begin
        // === MODO ORIGINAL: CONFIGURACIÓN MULTIJUGADOR EN RED (HOST) ===
        Cerebro.EsModoLocal := False;        // Aseguramos que la bandera local esté apagada

        // 1. Inicializa el tablero local cargando imágenes del disco duro y estructurando el Grid
        Cerebro.CargarImagenesDeCarpeta(cmbTematica.Selected.Text, ImageList1);
        Cerebro.IniciarJuego(cmbNoCar.Selected.Text, lytCartas, ImageList1, edtJ1.Text, edtJ2.Text);

        // 2. Serializa la partida en un objeto JSON para enviarla a Firebase
        ConfigObj := TJSONObject.Create;
        try
          ConfigObj.AddPair('cartas', cmbNoCar.Selected.Text);
          ConfigObj.AddPair('tematica', cmbTematica.Selected.Text);
          ConfigObj.AddPair('j1', edtJ1.Text);
          ConfigObj.AddPair('j2', edtJ2.Text);
          ConfigObj.AddPair('turno', TJSONNumber.Create(1)); // El Jugador 1 arranca la partida

          // Almacena la distribución exacta del barajado para que el invitado tenga el mismo mapa de juego
          OrdenArr := TJSONArray.Create;
          for I := 0 to High(Cerebro.Cartas) do
            OrdenArr.Add(Cerebro.Cartas[I].IDPareja);

          ConfigObj.AddPair('orden', OrdenArr);

          // 3. Sobrescribe el nodo central en la nube
          dmFirebase.SubirInicioJuego(ConfigObj.ToString);

        finally
          ConfigObj.Free;
        end;
        TimerSincronizador.Enabled := True;
        Cerebro.MiRol := 1; // Rol establecido como Creador de la partida (Jugador 1)
      end;
    end
  );
end;

procedure TForm1.btnConectarClick(Sender: TObject);
var
  JSONStr: string;
  ConfigObj: TJSONObject;
  OrdenArr: TJSONArray;
  I: Integer;
begin
  // OBJETIVO: Unirse a una partida existente como Jugador 2 (Invitado).
  // Descarga el estado inicial de la nube, configura la misma temática y tamaño,
  // y aplica de manera idéntica el array JSON orden sobre las cartas locales para que
  // ambos jugadores tengan el mismo tablero. Sube el nombre del J2 a la nube y define su rol como 2.

  // MODIFICADO: Aseguramos que si el jugador se conecta a internet, la bandera local se apague de inmediato.
  Cerebro.EsModoLocal := False;

  // 1. Descarga la configuración de la partida existente
  JSONStr := dmFirebase.DescargarPartida;

  if (JSONStr = 'null') or (JSONStr = '') then
  begin
    ShowMessage('Aún no hay ninguna partida iniciada en la nube.');
    Exit;
  end;

  // 2. Procesa la configuración enviada por el Host
  ConfigObj := TJSONObject.ParseJSONValue(JSONStr) as TJSONObject;
  try
    // 3. Recrea las mismas condiciones estéticas y funcionales del Host
    Cerebro.CargarImagenesDeCarpeta(ConfigObj.GetValue('tematica').Value, ImageList1);

    Cerebro.IniciarJuego(
      ConfigObj.GetValue('cartas').Value,
      lytCartas,
      ImageList1,
      ConfigObj.GetValue('j1').Value,
      ConfigObj.GetValue('j2').Value
    );

    // 4. EL TRUCO MULTIJUGADOR: Fuerza al Cerebro local a ordenar las cartas igual que el Host
    OrdenArr := ConfigObj.GetValue('orden') as TJSONArray;
    for I := 0 to OrdenArr.Count - 1 do
    begin
      Cerebro.Cartas[I].IDPareja := OrdenArr.Items[I].Value.ToInteger;
    end;

    ShowMessage('¡Conectado exitosamente a la partida de ' + ConfigObj.GetValue('j1').Value + '!');

  finally
    ConfigObj.Free;
  end;

  // Informa a Firebase el nombre real del Jugador 2 que se acaba de acoplar
  dmFirebase.SubirNombreJ2(edtJ1.Text);
  TimerSincronizador.Enabled := True;
  Cerebro.MiRol := 2; // Rol establecido como Invitado (Jugador 2)
end;

procedure TForm1.ActualizarMarcador(PtsJ1, PtsJ2, TurnoActual: Integer);
begin
  // OBJETIVO: Método callback que se ejecuta cada vez que hay un cambio en el juego.
  // Modifica las propiedades .Text de lblPointsJ1 y lblTurno usando los nombres actualizados de los jugadores.

  // Imprime de forma ordenada las estadísticas globales en la parte superior
  lblPointsJ1.Text := Cerebro.NombreJ1 + ': ' + PtsJ1.ToString + '  vs  ' +
                      Cerebro.NombreJ2 + ': ' + PtsJ2.ToString;

  if TurnoActual = 1 then
    lblTurno.Text := '¡Es turno de ' + Cerebro.NombreJ1 + '!'
  else
    lblTurno.Text := '¡Es turno de ' + Cerebro.NombreJ2 + '!';
end;

end.
