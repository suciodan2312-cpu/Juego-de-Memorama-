unit uMain;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes,
  System.Variants, FMX.Types, FMX.Controls, FMX.Forms,
  FMX.Graphics, FMX.Dialogs, FMX.Edit, FMX.ListBox,
  FMX.Controls.Presentation, FMX.StdCtrls,
  FMX.Layouts, uData, System.ImageList,
  FMX.ImgList, System.UIConsts;

type
  TForm1 = class(TForm)
    lytCartas: TLayout;
    btnIniciar: TButton;
    edtJ1: TEdit;
    cmbNoCar: TComboBox; // Cambiado de Edit a ComboBox
    edtJ2: TEdit;
    lblTurno: TLabel;
    lblPointsJ1: TLabel;
    Label2: TLabel;
    pnlTop: TPanel;
    pnlBajo: TPanel;
    ImageList1: TImageList;
    cmbTematica: TComboBox;

    procedure btnIniciarClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
  private
    procedure ActualizarMarcador(PtsJ1, PtsJ2, TurnoActual: Integer);
  public
  end;

var
  Form1: TForm1;

implementation

{$R *.fmx}

procedure TForm1.FormCreate(Sender: TObject);
begin
  Cerebro.OnActualizarUI := ActualizarMarcador;

  // 1. El cerebro llena el ComboBox de n·mero de cartas
  Cerebro.ConfigurarOpcionesCartas(cmbNoCar);

  // 2. El cerebro escanea la carpeta "Temas" y llena el ComboBox de temßticas
  Cerebro.ListarTemas(cmbTematica);
end;

procedure TForm1.btnIniciarClick(Sender: TObject);
begin
  // Validamos nombres rßpido
  if (edtJ1.Text = '') or (edtJ2.Text = '') then
  begin
    ShowMessage('Pon los nombres de los jugadores');
    Exit;
  end;

  // 1. Cargamos las fotos del tema seleccionado al ImageList
  Cerebro.CargarImagenesDeCarpeta(cmbTematica.Selected.Text, ImageList1);

  // 2. Iniciamos el juego
  Cerebro.IniciarJuego(
    cmbNoCar.Selected.Text,
    lytCartas,
    ImageList1,
    edtJ1.Text,
    edtJ2.Text
  );
end;

procedure TForm1.btnIniciarClick(Sender: TObject);
begin
  // El cerebro ahora recibe el texto del ComboBox y los nombres
  // ╔l se encarga de validar si estßn vacĒos o si el n·mero es par.
  Cerebro.IniciarJuego(
    cmbNoCar.Selected.Text,
    lytCartas,
    ImageList1,
    edtJ1.Text,
    edtJ2.Text
  );
end;

procedure TForm1.ActualizarMarcador(PtsJ1, PtsJ2, TurnoActual: Integer);
begin
  lblPointsJ1.Text := edtJ1.Text + ': ' + IntToStr(PtsJ1);
  Label2.Text      := edtJ2.Text + ': ' + IntToStr(PtsJ2);

  if TurnoActual = 1 then
  begin
    lblTurno.Text := 'Turno de: ' + edtJ1.Text;
    lblTurno.TextSettings.FontColor := TAlphaColorRec.Blue;
  end
  else
  begin
    lblTurno.Text := 'Turno de: ' + edtJ2.Text;
    lblTurno.TextSettings.FontColor := TAlphaColorRec.Red;
  end;
end;

end.
